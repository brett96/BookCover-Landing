=\"none\" stroke=\"rgba(255,255,255,.7)\" stroke-width=\"2\" stroke-linecap=\"round\"><circle cx=\"11\" cy=\"11\" r=\"8\"/><line x1=\"21\" y1=\"21\" x2=\"16.65\" y2=\"16.65\"/></svg><svg width=\"11\" height=\"11\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"rgba(255,255,255,.7)\" stroke-width=\"2\" stroke-linecap=\"round\"><circle cx=\"12\" cy=\"8\" r=\"4\"/><path d=\"M4 20c0-4 3.6-7 8-7s8 3 8 7\"/></svg></div></div><div style=\"background:white;border-bottom:1.5px solid #d4ead9;flex-shrink:0;display:flex\"><div style=\"flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:6px 1px 5px;border-bottom:2.5px solid transparent;margin-bottom:-1.5px\"><svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#888\" stroke-width=\"2.2\" stroke-linecap=\"round\"><path d=\"M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z\"/><polyline points=\"9 22 9 12 15 12 15 22\"/></svg><div style=\"font-size:8px;font-weight:500;color:#888;margin-top:2px\">Home</div></div><div style=\"flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:6px 1px 5px;border-bottom:2.5px solid transparent;margin-bottom:-1.5px\"><svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#888\" stroke-width=\"2.2\" stroke-linecap=\"round\"><polyline points=\"22 12 18 12 15 21 9 3 6 12 2 12\"/></svg><div style=\"font-size:8px;font-weight:500;color:#888;margin-top:2px\">My Plan</div></div><div style=\"flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:6px 1px 5px;border-bottom:2.5px solid #1d9e75;margin-bottom:-1.5px\"><svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#1d9e75\" stroke-width=\"2.2\" stroke-linecap=\"round\"><path d=\"M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z\"/></svg><div style=\"font-size:8px;font-weight:700;color:#1d9e75;margin-top:2px\">Your Assistant</div></div><div style=\"flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:6px 1px 5px;border-bottom:2.5px solid transparent;margin-bottom:-1.5px\"><svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#888\" stroke-width=\"2.2\" stroke-linecap=\"round\"><path d=\"M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z\"/></svg><div style=\"font-size:8px;font-weight:500;color:#888;margin-top:2px\">Benefits</div></div><div style=\"flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:6px 1px 5px;border-bottom:2.5px solid transparent;margin-bottom:-1.5px\"><svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#888\" stroke-width=\"2.2\" stroke-linecap=\"round\"><path d=\"M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18\"/></svg><div style=\"font-size:8px;font-weight:500;color:#888;margin-top:2px\">My Rx</div></div></div><div style=\"flex:1;overflow-y:auto;padding:10px;display:flex;flex-direction:column;background:#f5faf6\"><div style=\"display:flex;justify-content:flex-end;margin-bottom:10px\"><div style=\"background:#1d9e75;border-radius:12px 12px 3px 12px;padding:9px 11px;max-width:80%\"><div style=\"font-size:11px;color:white;line-height:1.65\">Is Humira covered on my plan?</div></div></div><div style=\"display:flex;gap:8px;align-items:flex-start;margin-bottom:10px\"><div style=\"width:26px;height:26px;background:#1d9e75;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center\"><svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"white\" stroke-width=\"2.2\" stroke-linecap=\"round\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/><path d=\"M9 12l2 2 4-4\"/></svg></div><div style=\"max-width:88%\"><div style=\"font-size:9px;color:#1d9e75;font-weight:700;margin-bottom:3px\">Your Assistant</div><div style=\"background:white;border-radius:12px 12px 12px 3px;padding:9px 11px;border:0.5px solid #d4ead9\"><div style=\"font-size:11px;color:#1a1a2e;line-height:1.65\">Yes — Humira (adalimumab) is covered on your Gold Plus HMO. Here are the details:<div style=\"background:#f5faf6;border:0.5px solid #d4ead9;border-radius:9px;padding:9px 11px;margin:7px 0\"><div style=\"display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-bottom:7px\"><div><div style=\"font-size:8px;color:#94A3B8;text-transform:uppercase;letter-spacing:.3px;margin-bottom:2px\">Formulary Tier</div><div style=\"font-size:12px;font-weight:700;color:#0F172A\">Tier 4 — Specialty</div></div><div><div style=\"font-size:8px;color:#94A3B8;text-transform:uppercase;letter-spacing:.3px;margin-bottom:2px\">Your Copay</div><div style=\"font-size:12px;font-weight:700;color:#1d9e75\">$100 per fill</div></div><div><div style=\"font-size:8px;color:#94A3B8;text-transform:uppercase;letter-spacing:.3px;margin-bottom:2px\">Prior Authorization</div><div style=\"font-size:12px;font-weight:700;color:#B45309\">&#9888; Required</div></div><div><div style=\"font-size:8px;color:#94A3B8;text-transform:uppercase;letter-spacing:.3px;margin-bottom:2px\">Quantity Limit</div><div style=\"font-size:12px;font-weight:700;color:#0F172A\">2 pens / 28 days</div></div></div><div style=\"border-top:0.5px solid #d4ead9;padding-top:6px;font-size:9px;color:#64748B;line-height:1.5\"><strong>Note:</strong> Prior authorization is arranged by your prescribing physician — no action needed from you.</div></div>Humira is a specialty drug, so it must be filled at a specialty pharmacy. Here are your best options at the lowest cost:<div style=\"background:#f5faf6;border:0.5px solid #d4ead9;border-radius:9px;padding:9px 11px;margin:7px 0\"><div style=\"font-size:9px;font-weight:700;color:#085041;text-transform:uppercase;letter-spacing:.4px;margin-bottom:7px\">Specialty Pharmacies Accepting Your Plan</div><div style=\"display:flex;align-items:cente