[{"type": "card", "tag": "Member Experience", "title": "A 30-second look inside", "sub": "The white-labeled member app your health plan would offer — under your own brand.", "accent": "intro"}, {"type": "screen", "tag": "FHIR Integration", "title": "Built from their real plan data", "sub": "Coverage, claims, deductibles and prescriptions — pulled live through the FHIR Patient-Access API.", "html": "<div style=\"display:flex;flex-direction:column;height:100%;background:#f5faf6;font-family:'DM Sans',sans-serif\"><div style=\"background:#1d9e75;padding:7px 12px;flex-shrink:0;display:flex;align-items:center;justify-content:space-between\"><div style=\"display:flex;align-items:center;gap:7px\"><div style=\"width:20px;height:20px;background:rgba(255,255,255,.18);border-radius:6px;display:flex;align-items:center;justify-content:center\"><svg width=\"9\" height=\"9\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"white\" stroke-width=\"2.2\" stroke-linecap=\"round\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/><path d=\"M9 12l2 2 4-4\"/></svg></div><div style=\"font-size:11px;font-weight:800;color:white;letter-spacing:-.2px\">BookCover</div></div><div style=\"display:flex;gap:8px;align-items:center\"><svg width=\"11\" height=\"11\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"rgba(255,255,255,.7)\" stroke-width=\"2\" stroke-linecap=\"round\"><circle cx=\"11\" cy=\"11\" r=\"8\"/><line x1=\"21\" y1=\"21\" x2=\"16.65\" y2=\"16.65\"/></svg><svg width=\"11\" height=\"11\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"rgba(255,255,255,.7)\" stroke-width=\"2\" stroke-linecap=\"round\"><circle cx=\"12\" cy=\"8\" r=\"4\"/><path d=\"M4 20c0-4 3.6-7 8-7s8 3 8 7\"/></svg></div></div><div style=\"background:white;border-bottom:1.5px solid #d4ead9;flex-shrink:0;display:flex\"><div style=\"flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:6px 1px 5px;border-bottom:2.5px solid transparent;margin-bottom:-1.5px\"><svg width=\"12\" height=\"1