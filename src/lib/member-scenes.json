mn;align-items:center;justify-content:center;padding:6px 1px 5px;border-bottom:2.5px solid transparent;margin-bottom:-1.5px\"><svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#8E8E93\" stroke-width=\"2.2\" stroke-linecap=\"round\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg><div style=\"font-size:8px;font-weight:400;color:#8E8E93;margin-top:2px\">My Feedback</div></div></div><div style=\"flex:1;overflow-y:auto;padding:10px;display:flex;flex-direction:column;background:#f5faf6\"><div style=\"font-size:15px;font-weight:800;color:#0F172A;margin-bottom:2px\">Plan Details</div><div style=\"font-size:9px;color:#64748B;margin-bottom:10px\">Sourced from Your Health Plan FHIR Coverage API &middot; Updated today</div><div style=\"background:white;border-radius:10px;border:0.5px solid #d4ead9;padding:10px 12px;margin-bottom:11px\"><div style=\"display:flex;align-items:flex-start;justify-content:space-between;padding:6px 0;border-bottom:0.5px solid #f5faf6\"><div style=\"font-size:10px;color:#94A3B8;flex-shrink:0;min-width:110px\">Plan Name</div><div style=\"font-size:10px;font-weight:600;color:#0F172A;text-align:right;\">Your Health Plan Gold Plus HMO</div></div><div style=\"display:flex;align-items:flex-start;justify-content:space-between;padding:6px 0;border-bottom:0.5px solid #f5faf6\"><div style=\"font-size:10px;color:#94A3B8;flex-shrink:0;min-width:110px\">Plan Type</div><div style=\"font-size:10px;font-weight:600;color:#0F172A;text-align:right;\">Medicare Advantage HMO</div></div><div style=\"display:flex;align-items:flex-start;justify-content:space-between;padding:6px 0;border-bottom:0.5px solid #f5faf6\"><div style=\"font-size:10px;color:#94A3B8;flex-shrink:0;min-width:110px\">Plan ID</div><div style=\"font-size:10px;font-weight:600;color:#0F172A;text-align:right;font-family:\"JetBrains Mono\",monospace;\">H1234-001</div></div><div style=\"display:flex;align-items:flex-start;justify-content:space-between;padding:6px 0;border-bottom:0.5px solid #f5faf6\"><div style=\"font-size:10px;color:#94A3B8;flex-shrink:0;min-width:110px\">Contract / PBP</div><div style=\"font-size:10px;font-weight:600;color:#0F172A;text-align:right;font-family:\"JetBrains Mono\",monospace;\">S1234 / 001</div></div><div style=\"display:flex;align-items:flex-start;justify-content:space-between;padding:6px 0;border-bottom:0.5px solid #f5faf6\"><div style=\"font-size:10px;color:#94A3B8;flex-shrink:0;min-width:110px\">Coverage Period</div><div style=\"font-size:10px;font-weight:600;color:#0F172A;text-align:right;\">Jan 1 – Dec 31, 2026</div></div><div style=\"display:flex;align-items:flex-start;justify-content:space-between;padding:6px 0;border-bottom:0.5px solid #f5faf6\"><div style=\"font-size:10px;color:#94A3B8;flex-shrink:0;min-width:110px\">Monthly Premium</div><div style=\"font-size:10px;font-weight:600;color:#0F172A;text-align:right;\">$0.00</div></div><div style=\"display:flex;align-items:flex-start;justify-content:space-between;padding:6px 0;border-bottom:0.5px solid #f5faf6\"><div style=\"font-size:10px;color:#94A3B8;flex-shrink:0;min-width:110px\">Drug Benefit</div><div style=\"font-size:10px;font-weight:600;color:#0F172A;text-align:right;\">Included (Part D)</div></div><div style=\"display:flex;align-items:center;justify-content:space-between;padding:6px 0\"><div style=\"font-size:10px;color:#94A3B8\">Special Designation</div><div style=\"font-size:10px;font-weight:600;color:#64748B\">None &mdash; Standard MA HMO<span style=\"display:block;font-size:8px;color:#94A3B8;font-weight:400;text-align:right\">CSNP / DSNP not applicable</span></div></div></div><div style=\"font-size:11px;font-weight:700;color:#085041;text-transform:uppercase;letter-spacing:.4px;margin-bottom:8px\">2026 Accumulators</div><div style=\"background:white;border-radius:10px;border:0.5px solid #d4ead9;padding:12px 13px;margin-bottom:8px\"><div style=\"margin-bottom:10px\"><div style=\"display:flex;justify-content:space-between;margin-bottom:3px\"><div style=\"font-size:11px;font-weight:600;color:#334155\">Medical Deductible</div><div style=\"font-size:11px;font-weight:700;color:#1d9e75\">$350 <span style=\"font-weight:400;color:#94A3B8;font-size:10px\">/ $1,500</span></div></div><div style=\"background:#d4ead9;border-radius:4px;height:7px;overflow:hidden\"><div style=\"background:#1d9e75;height:100%;width:23%;border-radius:4px\"></div></div><div style=\"font-size:9px;color:#94A3B8;margin-top:2px\">23% met &middot; $1,150 remaining</div></div><div style=\"margin-bottom:10px\"><div style=\"display:flex;justify-content:space-between;margin-bottom:3px\"><div style=\"font-size:11px;font-weight:600;color:#334155\">Rx Deductible</div><div style=\"font-size:11px;font-weight:700;color:#1d9e75\">$0 <span style=\"font-weight:400;color:#94A3B8;font-size:10px\">/ $250</span></div></div><div style=\"background:#d4ead9;border-radius:4px;height:7px;overflow:hidden\"><div style=\"background:#1d9e75;height:100%;width:0%;border-radius:4px\"></div></div><div style=\"font-size:9px;color:#94A3B8;margin-top:2px\">0% met &middot; $250 remaining</div></div><div style=\"margin-bottom:10px\"><div style=\"display:flex;justify-content:space-between;margin-bottom:3px\"><div style=\"font-size:11px;font-weight:600;color:#334155\">Medical OOPM</div><div style=\"font-size:11px;font-weight:700;color:#E07856\">$1,200 <span style=\"font-weight:400;color:#94A3B8;font-size:10px\">/ $5,000</span></div></div><div style=\"background:#d4ead9;border-radius:4px;height:7px;overflow:hidden\"><div style=\"background:#E07856;height:100%;width:24%;border-radius:4px\"></div></div><div style=\"font-size:9px;color:#94A3B8;margin-top:2px\">24% met &middot; $3,800 remaining</div></div><div style=\"margin-bottom:10px\"><div style=\"display:flex;justify-content:space-between;margin-bottom:3px\"><div style=\"font-size:11px;font-weight:600;color:#334155\">Drug OOPM</div><div style=\"font-size:11px;f